# Database
DB_NAME=template
DB_USERNAME=template
DB_PASSWORD=changeme

# JWT Keystore (production only — dev uses auto-generated in-memory keypair)
JWT_KEYSTORE_LOCATION=jwt-keystore.p12
JWT_KEYSTORE_PASSWORD=changeit
JWT_KEY_ALIAS=jwt

# CORS (production only — dev defaults to localhost:3000 and localhost:5173)
APP_CORS_ALLOWED_ORIGINS=https://app.example.com

# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Google OAuth2 (required for authentication)
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com

# Apple Sign In (required for Apple authentication)
# Use the iOS app bundle ID (e.g., com.yourcompany.yourapp)
# For web clients, use the Services ID registered in Apple Developer Portal instead
APPLE_BUNDLE_ID=com.example.myapp

# Refresh Token (optional — defaults to 30 days)
REFRESH_TOKEN_EXPIRY_DAYS=30
